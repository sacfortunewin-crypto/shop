{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/tela1/index.html"
    },
    {
      "source": "/index.html",
      "destination": "/tela1/index.html"
    },
    {
      "source": "/checkout",
      "destination": "/tela1/checkout/index.html"
    },
    {
      "source": "/checkout/",
      "destination": "/tela1/checkout/index.html"
    },
    {
      "source": "/checkout/api/config.php",
      "destination": "/api/config"
    },
    {
      "source": "/checkout/api/transaction.php",
      "destination": "/api/transaction"
    },
    {
      "source": "/checkout/api/webhook.php",
      "destination": "/api/webhook"
    },
    {
      "source": "/checkout/api/:path*",
      "destination": "/api/not-found"
    },
    {
      "source": "/:path*",
      "destination": "/tela1/:path*"
    }
  ]
}
